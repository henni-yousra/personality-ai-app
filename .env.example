# ──────────────────────────────────────────────────────────────
# Persona AI — Variables d'environnement
# Copiez ce fichier en ".env" et renseignez vos valeurs.
# ──────────────────────────────────────────────────────────────

# Clé API Groq (gratuit, sans CB)
# Créez votre clé sur : https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# SMTP — envoi des rapports par e-mail (fonctionne avec n'importe quel fournisseur)
#
# Gmail (port 465 SSL) :
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=465
#   Mot de passe → myaccount.google.com → Sécurité → Mots de passe des applications
#
# Outlook / Hotmail (port 587 STARTTLS) :
#   SMTP_HOST=smtp-mail.outlook.com  SMTP_PORT=587
#
# Yahoo (port 465 SSL) :
#   SMTP_HOST=smtp.mail.yahoo.com  SMTP_PORT=465
#
# OVH / autre hébergeur (port 587 STARTTLS) :
#   SMTP_HOST=ssl0.ovh.net  SMTP_PORT=587

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=votre.email@example.com
SMTP_PASSWORD=votre_mot_de_passe_ou_app_password
SMTP_FROM_NAME=Persona Test
