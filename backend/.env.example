# Copiez ce fichier vers .env et renseignez les valeurs (ne commitez jamais .env).

# Obligatoire pour l’envoi des rapports par e-mail (l’un des deux couples au choix) :
SMTP_USER=votre.adresse@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Alias Gmail acceptés à la place de SMTP_* :
# GMAIL_USER=votre.adresse@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optionnel :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_FROM_NAME=Persona Test

# Clé API Groq (génération du rapport) :
# GROQ_API_KEY=...
