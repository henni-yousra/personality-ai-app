# Copiez ce fichier vers .env et renseignez les valeurs (ne commitez jamais .env).

# Obligatoire pour l’envoi des rapports par e-mail (l’un des deux couples au choix) :
SMTP_USER=votre.adresse@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Alias Gmail acceptés à la place de SMTP_* :
# GMAIL_USER=votre.adresse@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optionnel :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_FROM_NAME=personAI Test

# Clé API Groq (rapport + questions si options ci-dessous activées) :
# GROQ_API_KEY=gsk_...

# Génération LLM d’une nouvelle formulation de question (équivalente psychométriquement,
# mêmes options). Désactivé par défaut — mettre true pour la soutenance / démo.
# LLM_QUESTION_GENERATION=true

# Reformulation LLM du texte affiché (après génération si les deux sont true).
# LLM_QUESTION_REFORMULATION=true

# Déploiement : origines du front (virgules). Sans slash final. Ex. :
# CORS_ORIGINS=https://mon-app.netlify.app
# Forcer l’autorisation *.netlify.app (local ou hors Render) :
# CORS_ALLOW_NETLIFY=true
# Sur Render (RENDER=true), *.netlify.app, *.vercel.app, *.github.io, *.pages.dev sont autorisés par défaut.
# Désactiver ces motifs et n’utiliser que CORS_ORIGINS + localhost :
# CORS_STRICT=true
